      "icons": [
        {
          "src": "/icon-144x144.png",
          "sizes": "144x144"
        }
      ]
    },
    {
      "name": "Charts",
      "short_name": "Charts",
      "description": "View top songs and trending music",
      "url": "/charts",
      "icons": [
        {
          "src": "/icon-144x144.png",
          "sizes": "144x144"
        }
      ]
    }
  ],
  "features": [
    "Cross Platform",
    "Audio Streaming",
